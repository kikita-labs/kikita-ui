{
  "$schema": "../../node_modules/ng-packagr/ng-package.schema.json",
  "dest": "../../dist/ui",
  "assets": [
    {
      "glob": "**/*",
      "input": "src/styles",
      "output": "styles"
    },
    {
      "glob": "**/*",
      "input": "schematics",
      "output": "schematics"
    }
  ],
  "lib": {
    "entryFile": "src/public-api.ts"
  },
  "allowedNonPeerDependencies": ["@angular-devkit/schematics"]
}
